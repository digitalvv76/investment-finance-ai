# ==========================================
# Investment Finance AI Agent — API Keys
# ==========================================
# Copy this file to .env and fill in your keys.
# .env is git-ignored — NEVER commit it.

# ---- Critical (at least one LLM key required) ----
# DeepSeek LLM (primary): https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_key_here

# Anthropic Claude (alternative): https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Telegram Bot: message @BotFather on Telegram to create one
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ---- Recommended ----
# Pushover (phone emergency push): https://pushover.net
PUSHOVER_APP_TOKEN=your_pushover_app_token_here
PUSHOVER_USER_KEY=your_pushover_user_key_here

# ---- Optional ----
# FRED (美联储经济数据): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Alpha Vantage (多源金融数据): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Binance (加密货币交易): https://www.binance.com/en/support/faq/how-to-create-api-keys-on-binance-360002502072
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
