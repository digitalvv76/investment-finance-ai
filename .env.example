# ============================================================
# Investment Finance AI Agent — 环境变量
# 复制此文件为 .env 并填入你的 API Keys
# ============================================================

# FRED API Key — 80万+ 宏观经济指标 (免费注册)
# 注册地址: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage API Key — 多源金融数据聚合 (免费注册)
# 注册地址: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Binance API (可选 — 实盘交易)
# 注册地址: Binance API 管理页面
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
