# ==========================================
# Investment Finance AI Agent — API Keys 模板
# ==========================================
# 复制为 .env 并填入真实 Key。.env 已被 git-ignored。
# 每次新增 Key 后同步更新本文件。

# ---- 编码 ----
PYTHONIOENCODING=utf-8

# ---- Critical (必需) ----
# DeepSeek LLM (主): https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_key_here

# Telegram Bot: 在 Telegram 找 @BotFather 创建
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ---- Recommended (推荐) ----
# Anthropic Claude (备用 LLM): https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Pushover 手机紧急推送: https://pushover.net
PUSHOVER_APP_TOKEN=your_pushover_app_token_here
PUSHOVER_USER_KEY=your_pushover_user_key_here

# Finnhub 个股新闻 API: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# Twitter/X auth_token (Playwright cookie 认证)
TWITTER_AUTH_TOKEN=your_twitter_auth_token_here

# FRED 美联储经济数据: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Alpha Vantage 多源金融数据: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ---- Optional (可选) ----
# Web Dashboard 管理密码
WEB_USERNAME=admin
WEB_PASSWORD=change_me

# Binance 加密货币交易
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ---- 网络 (仅本地 Windows 开发需要) ----
# ECS 部署时必须留空！（Docker 容器内无代理）
HTTPS_PROXY=http://127.0.0.1:7897
HTTP_PROXY=http://127.0.0.1:7897
WEB_PORT=8080
WEB_DASHBOARD_URL=http://localhost:8080
