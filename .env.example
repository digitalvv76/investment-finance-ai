# ==========================================
# Investment Finance AI Agent — API Keys
# ==========================================
# Copy this file to .env and fill in your keys.
# .env is git-ignored — NEVER commit it.

# Tier 2 — 进阶数据源 (免费注册)
# FRED (美联储经济数据): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# Alpha Vantage (多源金融数据): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Tier 3 — 执行层 (需交易所账户)
# Binance (加密货币交易): https://www.binance.com/en/support/faq/how-to-create-api-keys-on-binance-360002502072
BINANCE_API_KEY=your_binance_key_here
BINANCE_SECRET_KEY=your_binance_secret_here
