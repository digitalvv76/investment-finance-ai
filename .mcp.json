{
  "mcpServers": {
    "yfinance": {
      "command": "uvx",
      "args": ["mcp-yfinance"],
      "env": {}
    },
    "stock-scanner": {
      "command": "npx",
      "args": ["-y", "@stock-scanner/mcp"],
      "env": {}
    },
    "finance": {
      "command": "npx",
      "args": ["-y", "@anthropic/finance-mcp"],
      "env": {
        "ALPHA_VANTAGE_API_KEY": "${ALPHA_VANTAGE_API_KEY}"
      }
    },
    "coingecko": {
      "command": "npx",
      "args": ["-y", "@coingecko/coingecko-mcp"],
      "env": {}
    },
    "fred": {
      "command": "npx",
      "args": ["-y", "@anthropic/fred-mcp"],
      "env": {
        "FRED_API_KEY": "${FRED_API_KEY}"
      }
    },
    "sec-edgar": {
      "command": "uvx",
      "args": ["sec-edgar-mcp"],
      "env": {}
    },
    "cn-finance": {
      "command": "uvx",
      "args": ["cn-finance-mcp"],
      "env": {}
    },
    "crypto-trade": {
      "command": "npx",
      "args": ["-y", "crypto-trade-mcp"],
      "env": {
        "BINANCE_API_KEY": "${BINANCE_API_KEY}",
        "BINANCE_SECRET_KEY": "${BINANCE_SECRET_KEY}"
      }
    }
  }
}
