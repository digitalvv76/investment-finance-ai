{
  "mcpServers": {
    "yfinance": {
      "command": "uvx",
      "args": ["yahoo-finance-mcp-server"]
    },
    "cn-finance": {
      "command": "uvx",
      "args": ["cn-financial-mcp"],
      "_note": "Package not yet available on PyPI (2026-06-30). Use stock-scanner tradingview_scan with exchange=SHA/SHE for A-shares as fallback."
    },
    "coingecko": {
      "command": "npx",
      "args": ["-y", "@coingecko/coingecko-mcp"]
    },
    "fred": {
      "command": "npx",
      "args": ["-y", "fred-mcp-server"],
      "env": {
        "FRED_API_KEY": "${FRED_API_KEY}"
      }
    },
    "finance": {
      "command": "npx",
      "args": ["-y", "finance-mcp-server"],
      "env": {
        "ALPHA_VANTAGE_API_KEY": "${ALPHA_VANTAGE_API_KEY}"
      }
    },
    "stock-scanner": {
      "command": "npx",
      "args": ["-y", "stock-scanner-mcp", "--enable-workspace"],
      "env": {
        "FINNHUB_API_KEY": "${FINNHUB_API_KEY}"
      }
    },
    "sec-edgar": {
      "command": "uvx",
      "args": ["sec-edgar-mcp"]
    },
    "crypto-trade": {
      "command": "npx",
      "args": ["-y", "crypto-mcp-server"],
      "env": {
        "BINANCE_API_KEY": "${BINANCE_API_KEY}",
        "BINANCE_SECRET_KEY": "${BINANCE_SECRET_KEY}"
      }
    },
    "anysearch": {
      "type": "streamable-http",
      "url": "https://api.anysearch.com/mcp"
    }
  }
}
